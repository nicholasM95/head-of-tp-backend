{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "assignees": [
    "nicholasM95"
  ],
  "baseBranchPatterns": [
    "develop"
  ],
  "packageRules": [
    {
      "matchFileNames": [
        ".github/workflows/**",
        "infra/prod/**",
        ".mvn/wrapper/**"
      ],
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": true
    }
  ]
}